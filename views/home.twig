                Verileriniz bizimle güvende. YouTube URL'leri sadece işleme alınmak için geçici olarak tutulur. İndirme bittiği an sunucudan silinir. Ödeme işlemleri doğrudan PayTR altyapısı üzerinden şifreli olarak gerçekleşir. Çerezler (cookies) sadece lisans anahtarınızı tarayıcıda hatırlamak için kullanılır.
            </div>
        </div>

    </div>
</section>
       <footer class="mt-40 pt-10 border-t border-white/5 text-center">
   
    <p class="text-gray-600 text-xs">
        &copy; 2026 PlaylistZip AI. ACE Labs tarafından geliştirilmiştir. <br>
        Tüm hakları saklıdır.
    </p>
</footer>
    </div>
<script>
let selectedPlan = ''; // Hangi planın seçildiğini burada tutacağız

// 1. MODALI AÇAN FONKSİYON
function openModal(planType) {
    selectedPlan = planType; // Seçilen planı kaydet
    const modal = document.getElementById('paymentModal');
    modal.classList.remove('hidden'); // Modalı görünür yap
    
    // Animasyon için hafif bir gecikme
    setTimeout(() => {
        document.getElementById('modalContent').classList.remove('scale-95', 'opacity-0');
        document.getElementById('modalContent').classList.add('scale-100', 'opacity-100');
    }, 10);
}

// 2. ÖDEMEYİ BAŞLATAN (ESKİ buyPlan'IN YENİ HALİ)
function processPayment(event) {
    event.preventDefault(); // Sayfanın yenilenmesini engelle

    const email = document.getElementById('customerEmail').value;
    
    // Senin eski validasyon mantığın
    if (!email || !email.includes('@')) {
        alert("Geçerli bir e-posta adresi girmelisiniz!");
        return;
    }

    // Butonu yükleniyor moduna sokalım (Şıklık önemli)
    const btn = document.getElementById('payButton');
    btn.disabled = true;
    btn.innerText = "Yönlendiriliyor...";

    // SENİN FORM OLUŞTURMA MANTIĞIN (En garanti yöntem budur)
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/pay/create-checkout';

    const planInput = document.createElement('input');
    planInput.type = 'hidden';
    planInput.name = 'planType';
    planInput.value = selectedPlan;

    const emailInput = document.createElement('input');
    emailInput.type = 'hidden';
    emailInput.name = 'email';
    emailInput.value = email;

    form.appendChild(planInput);
    form.appendChild(emailInput);
    document.body.appendChild(form);
    
    // Ve bombayı patlat:
    form.submit();
}

// Modalı kapatma fonksiyonu
function closeModal() {
    document.getElementById('modalContent').classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
        document.getElementById('paymentModal').classList.add('hidden');
    }, 200);
}

// Ödemeyi Başlat
async function handleCheckout(event) {
    event.preventDefault(); // Sayfanın normal yenilenmesini durdur
    
    const email = document.getElementById('customerEmail').value;
    const payButton = document.getElementById('payButton');

    // 1. Basit Email Kontrolü
    if (!email || !email.includes('@')) {
        alert("Lütfen geçerli bir e-posta adresi giriniz!");
        return;
    }

    // 2. Butonu Yükleniyor Moduna Sok (Tasarımın bozulmasın)
    payButton.disabled = true;
    payButton.innerHTML = `
        <svg class="animate-spin h-5 w-5 text-white mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>Ödeme Sayfasına Gidiliyor...</span>
    `;

    // 3. SENİN SAĞLAM FORM MANTIĞIN
    // Fetch yerine direkt form oluşturup POST atıyoruz. 
    // Bu sayede res.render('pay') komutu tarayıcıda temiz bir sayfa açar.
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/pay/create-checkout';

    // Plan Tipi (Modal açıldığında global değişkene atamıştık)
    const planInput = document.createElement('input');
    planInput.type = 'hidden';
    planInput.name = 'planType';
    planInput.value = currentPlan; // openModal(plan) fonksiyonunda set edilen değişken

    // Email
    const emailInput = document.createElement('input');
    emailInput.type = 'hidden';
    emailInput.name = 'email';
    emailInput.value = email;

    form.appendChild(planInput);
    form.appendChild(emailInput);
    document.body.appendChild(form);
    
    // Ve dükkanı PayTR'ye yönlendiriyoruz
    form.submit();
}

function toggleLicenseInput() {
    const btn = document.getElementById('btn-show-license');
    const inputArea = document.getElementById('license-input-area');

    if (inputArea.classList.contains('hidden')) {
        // Butonu gizle, girişi göster
        btn.classList.add('hidden');
        inputArea.classList.remove('hidden');
        // Hafif bir gecikmeyle animasyonu başlat
        setTimeout(() => {
            inputArea.classList.remove('opacity-0', '-translate-y-4');
        }, 10);
    }
}

function applyVipTheme() {
    console.log(">>> VIP Tema Uygulama Başladı...");

    // Kullanılacak tüm elementleri güvenli bir listeye alalım
    const elements = {
        wrapper: document.getElementById('license-input-wrapper'),
        badge: document.getElementById('vip-badge'),
        container: document.getElementById('downloadContainer')
    };

    // Her birini tek tek kontrol et (Eğer varsa işlem yap)
    if (elements.wrapper) {
        elements.wrapper.classList.add('hidden');
        console.log("✅ Giriş alanı gizlendi.");
    } else {
        console.warn("⚠️ 'license-input-wrapper' bulunamadı, gizleme atlandı.");
    }

    if (elements.badge) {
        elements.badge.classList.remove('hidden');
        elements.badge.classList.add('flex');
        console.log("✅ VIP Rozeti gösterildi.");
    } else {
        console.warn("⚠️ 'vip-badge' bulunamadı, rozet gösterimi atlandı.");
    }

    // Görsel efektleri her durumda uygula
    document.body.classList.add('premium-mode');
    document.documentElement.style.setProperty('--primary-color', '#3b82f6');
}

// 2. Lisans Aktifleştirme Fonksiyonu
async function activateLicense() {
    const keyInput = document.getElementById('license-key-input');
    const emailInput = document.getElementById('userEmail'); // Input ID'niz bu değilse düzeltin

    if (!keyInput) {
        console.error("❌ Hata: 'license-key-input' ID'li input bulunamadı!");
        return;
    }

    const key = keyInput.value.trim();
    const email = emailInput ? emailInput.value.trim() : "";

    if (!key) {
        alert("Lütfen anahtarınızı girin.");
        return;
    }

    try {
        const res = await fetch(`/api/verify-license?key=${key}&email=${email}`);
        const data = await res.json();

        if (data.valid) {
            localStorage.setItem('license_key', key);
            localStorage.setItem('license_email', email);
            
            // Hata olsa bile activateLicense durmasın diye try-catch içine alıyoruz
            try {
                applyVipTheme();
            } catch (e) {
                console.error("Tema uygulanırken hata oluştu ama lisans geçerli:", e);
            }
            
            alert("Tebrikler! Premium Turbo Mod aktif.");
        } else {
            alert(data.message || "Geçersiz anahtar.");
        }
    } catch (error) {
        console.error("Bağlantı hatası:", error);
        alert("Sunucuya ulaşılamıyor.");
    }
}

// 3. Sayfa Yüklendiğinde Otomatik Kontrol
window.addEventListener('DOMContentLoaded', () => {
    const savedKey = localStorage.getItem('license_key');
    if (savedKey) {
        // Sayfa yeni yüklendiğinde de hata vermemesi için güvenli çağırıyoruz
        setTimeout(applyVipTheme, 100); 
    }
});
function startDownload() {
    const playlistId = "ALINAN_PLAYLIST_ID";
    const userKey = localStorage.getItem('license_key') || ''; // Varsa al, yoksa boş gönder
    
    // URL'ye hem ID'yi hem de KEY'i ekliyoruz
    window.location.href = `/api/download-playlist-zip?id=${playlistId}&key=${userKey}`;
}
    // Global değişken olarak tanımlayalım ki her yerden erişilebilsin
    async function processPlaylist() {
    console.log("Hazırla butonuna basıldı...");
    const urlInput = document.getElementById('playlistUrl').value;
    
    // URL Kontrolü
    if (!urlInput.includes('list=')) {
        alert('Lütfen geçerli bir YouTube Playlist URL\'si girin!');
        return;
    }

    const urlParams = new URLSearchParams(new URL(urlInput).search);
    const playlistId = urlParams.get('list');

    // UI Elementleri
    const videoContainer = document.getElementById('videoContainer');
    const videoList = document.getElementById('videoList');
    const statusTitle = document.getElementById('statusTitle');
    const statusArea = document.getElementById('statusArea');
    const finalDownloadBtn = document.getElementById('finalDownloadBtn');
    const successCard = document.getElementById('successCard');

    // UI Reset
    statusArea.classList.remove('hidden');
    statusTitle.innerText = "Playlist Analiz Ediliyor (Bu işlem büyük listelerde sürebilir)...";
    videoContainer.classList.add('hidden');
    successCard.classList.add('hidden');

    try {
        // 1. Videoları Backend'den Çek
        const response = await fetch(`/api/get-playlist-info?id=${playlistId}`);
        
        if (!response.ok) throw new Error("Sunucu hatası: " + response.status);
        
        const data = await response.json(); // Data burada tanımlanıyor

        if (!data || !data.videos || data.videos.length === 0) {
            throw new Error("Playlist boş veya gizli.");
        }

        // 2. Videoları Listele
        videoList.innerHTML = data.videos.map((v, index) => `
            <div class="flex items-center gap-4 bg-white/5 p-4 rounded-2xl border border-white/10 hover:bg-white/10 transition-all group animate-fade-in" style="animation-delay: ${index * 30}ms">
                <div class="relative w-24 h-16 flex-shrink-0 overflow-hidden rounded-lg shadow-lg">
                    <img src="${v.thumbnail}" referrerpolicy="no-referrer" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors"></div>
                </div>
                <div class="flex-1 min-w-0 text-left">
                    <p class="text-sm font-semibold text-gray-100 truncate mb-1">${v.title}</p>
                    <p class="text-[10px] text-gray-500 uppercase tracking-widest font-bold">MP3 Audio - 320kbps</p>
                </div>
            </div>
        `).join('');

        // 3. Arayüzü Güncelle
        videoContainer.classList.remove('hidden');
        statusTitle.innerText = `${data.videos.length} Video Listelendi.`;
        
        // 4. İndirme Butonuna Olayı Bağla
        finalDownloadBtn.onclick = function() {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = `<span class="animate-pulse">Hazırlanıyor...</span>`;
            statusTitle.innerText = "Sunucu paralel paketleme yapıyor, lütfen bekleyin...";

            // İndirmeyi başlat
          
            const currentKey = localStorage.getItem('license_key');
            const downloadUrl = `/api/download-playlist-zip?id=${playlistId}&key=${currentKey}`;
            window.location.href = downloadUrl;

            // Başarı ekranına geçiş (Playlist uzunsa süreyi artırıyoruz)
            const waitTime = data.videos.length > 50 ? 10000 : 5000;
            
            setTimeout(() => {
                videoContainer.classList.add('hidden');
                statusArea.classList.add('hidden');
                successCard.classList.remove('hidden');
                
                try {
                    if (typeof confetti === 'function') {
                        confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
                    }
                } catch (e) { console.error("Konfeti hatası"); }

                btn.disabled = false;
                btn.innerHTML = "Tümünü MP3 Olarak İndir (.zip)";
            }, waitTime);
        };

    } catch (err) {
        console.error("Hata Detayı:", err);
        alert("Hata: " + err.message);
        statusArea.classList.add('hidden');
    }
}
</script>
<div id="paymentModal" class="fixed inset-0 z-50 hidden flex items-center justify-center px-4">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeModal()"></div>
    
    <div class="glass max-w-md w-full p-8 rounded-3xl border border-white/10 shadow-2xl relative z-10 scale-95 transition-transform duration-300" id="modalContent">
        <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-500/20 rounded-full text-blue-400 mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <h3 class="text-2xl font-black uppercase tracking-tighter">Son Bir Adım</h3>
            <p class="text-gray-400 text-sm mt-1">Lisans anahtarınızın gönderileceği e-posta adresini girin.</p>
        </div>

        <form id="checkoutForm" onsubmit="processPayment(event)" class="space-y-6">
            <input type="hidden" id="selectedPlan" name="planType" value="">
            
            <div class="mb-6">
                <label class="block text-xs font-bold text-gray-500 uppercase mb-2 ml-1">E-Posta Adresiniz</label>
                <input type="email" id="customerEmail" required 
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white placeholder-gray-600 focus:outline-none focus:border-blue-500 transition-all"
                    placeholder="ornek@mail.com">
            </div>

            <button type="submit" id="payButton" class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-xl transition-all shadow-lg shadow-blue-600/20 flex items-center justify-center space-x-2">
                <span>Güvenli Ödemeye Geç</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </button>
        </form>

        <button onclick="closeModal()" class="mt-4 w-full text-gray-500 text-xs hover:text-gray-300 transition">Vazgeç</button>
    </div>
</div>
</body>
</html>