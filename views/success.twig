{% extends 'layout.twig' %}

{% block content %}
<div class="max-w-xl mx-auto mt-20 p-10 bg-gray-900/50 backdrop-blur-xl border border-white/10 rounded-3xl text-center">
    
    {% if status == 'completed' %}
        <div class="text-green-500 text-6xl mb-4">✓</div>
        <h1 class="text-2xl font-bold text-white mb-2">Ödeme Başarılı!</h1>
        <p class="text-gray-400 mb-8">PlaylistZip Premium lisansınız aşağıdadır:</p>
        
        <div class="bg-black/50 p-6 rounded-2xl border border-dashed border-green-500/50 mb-6">
            <code class="text-3xl font-mono text-green-400 tracking-wider">{{ licenseKey }}</code>
        </div>
        
        <p class="text-xs text-gray-500">Geçerlilik Tarihi: {{ expireDate | date('d.m.Y') }}</p>
        <button onclick="window.location.href='/'" class="mt-8 bg-white text-black px-6 py-2 rounded-full font-bold">Kullanmaya Başla</button>

    {% else %}
        <div class="animate-spin text-blue-500 text-6xl mb-4">↻</div>
        <h1 class="text-xl text-white">Lisansınız Oluşturuluyor...</h1>
        <p class="text-gray-400">Ödemeniz onaylandı, lisans anahtarınız saniyeler içinde burada belirecek.</p>
        <script>setTimeout(() => { location.reload(); }, 3000);</script>
    {% endif %}

</div>
{% endblock %}