<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://quge5.com/88/tag.min.js" data-zone="219105" async data-cfasync="false"></script>
    <link rel="icon" type="image/x-icon" href="/favicon.png">
    <title>PlaylistZip - YouTube Playlist Downloader</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0f172a; /* Koyu modern arka plan */
            color: white;
        }
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="bg-[#0f172a] min-h-screen text-gray-100">

    <nav class="p-6">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <h1 class="text-6xl font-extrabold mb-6 tracking-tighter">Playlist<span class="gradient-text">Zip</span></h1>
            <div class="space-x-6 text-sm font-medium text-gray-400">
                <a href="/" class="hover:text-white transition">Ana Sayfa</a>
                <a href="#" class="hover:text-white transition">Yardım</a>
            </div>
        </div>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

   <footer class="mt-40 pt-10 border-t border-white/5 text-center">
   
    <p class="text-gray-600 text-xs">
        &copy; 2026 PlaylistZip AI. ACE Labs tarafından geliştirilmiştir. <br>
        Tüm hakları saklıdır.
    </p>
</footer>

</body>
</html>